# Public API endpoint the app fetches articles from. Copy this file to .env
# and override if you need to point at a different endpoint (e.g. staging).
# No .env file is required to run the app — nuxt.config.ts ships a working default.
NUXT_PUBLIC_ARTICLES_API_URL=https://mocki.io/v1/38c57ea8-5688-4a36-9629-8c9616754eb8

# Port the dev/preview/production server listens on. Nitro (Nuxt's server
# engine) reads this natively — no nuxt.config.ts change is needed for it.
# Defaults to 3000 if unset.
PORT=3000
